local function updateViewport(targetPlayer)
	if vpClone then vpClone:Destroy() vpClone = nil end
	if vpConnection then vpConnection:Disconnect() vpConnection = nil end
	noTargetLabel.Visible = true
	if not targetPlayer or not targetPlayer.Character then return end
	local tChar = targetPlayer.Character
	local cloneOk, clone = pcall(function() return tChar:Clone() end)
	if not cloneOk then return end
	vpClone = clone
	vpClone.Parent = viewport
	noTargetLabel.Visible = false
	pcall(function()
		for _, v in pairs(vpClone:GetDescendants()) do
			if v:IsA("Script") or v:IsA("LocalScript") then v:Destroy() end
		end
	end)
	local root = vpClone:FindFirstChild("HumanoidRootPart")
	if root then
		vpCamera.CFrame = CFrame.new(
			root.Position + Vector3.new(0, 1, 4.5),
			root.Position + Vector3.new(0, 1, 0)
		)
	end
	vpConnection = game:GetService("RunService").RenderStepped:Connect(function()
		if not targetPlayer or not targetPlayer.Character then return end
		for _, part in pairs(vpClone:GetDescendants()) do
			if part:IsA("BasePart") then
				local live = targetPlayer.Character:FindFirstChild(part.Name)
				if live and live:IsA("BasePart") then
					part.CFrame = live.CFrame
				end
			end
		end
	end)
end

