local camera = workspace.CurrentCamera
local RS = game:GetService("RunService")

local espHighlight = nil
local tracerLine = nil
local espConnection = nil

local function hideESP()
	if espHighlight then espHighlight:Destroy() espHighlight = nil end
	if tracerLine then tracerLine:Remove() tracerLine = nil end
	if espConnection then espConnection:Disconnect() espConnection = nil end
	espNameLabel.Visible = false
	espDistLabel.Visible = false
end

local function startESP(targetPlayer)
	hideESP()
	if not targetPlayer then return end

	if espHighlight then espHighlight:Destroy() end
	espHighlight = Instance.new("Highlight")
	espHighlight.FillTransparency = 0.6
	espHighlight.OutlineTransparency = 0
	espHighlight.FillColor = Color3.fromRGB(255, 0, 0)
	espHighlight.OutlineColor = Color3.fromRGB(255, 50, 50)
	espHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	espHighlight.Adornee = targetPlayer.Character
	espHighlight.Parent = workspace

	tracerLine = Drawing.new("Line")
	tracerLine.Visible = true
	tracerLine.Color = Color3.fromRGB(255, 200, 0)
	tracerLine.Thickness = 2
	tracerLine.Transparency = 1

	espConnection = RS.RenderStepped:Connect(function()
		if not targetPlayer or not targetPlayer.Character then
			hideESP() return
		end

		local tChar = targetPlayer.Character
		local tHRP = tChar:FindFirstChild("HumanoidRootPart")
		local tHead = tChar:FindFirstChild("Head")
		if not tHRP or not tHead then hideESP() return end

		if espHighlight and espHighlight.Adornee ~= tChar then
			espHighlight.Adornee = tChar
		end

		local headSP, onScreen = camera:WorldToViewportPoint(tHead.Position)
		local vp = camera.ViewportSize

		if onScreen and headSP.Z > 0 then
			local from = Vector2.new(vp.X / 2, vp.Y)
			local to = Vector2.new(headSP.X, headSP.Y)
			tracerLine.From = from
			tracerLine.To = to
			tracerLine.Visible = true

			local dist = math.floor((tHRP.Position - hrp.Position).Magnitude)
			local topSP = camera:WorldToViewportPoint(tHRP.Position + Vector3.new(0, 3.2, 0))

			espNameLabel.Text = targetPlayer.Name
			espNameLabel.Size = UDim2.new(0, 140, 0, 16)
			espNameLabel.Position = UDim2.new(0, topSP.X - 70, 0, topSP.Y - 20)
			espNameLabel.Visible = true

			espDistLabel.Text = dist .. " studs"
			espDistLabel.Size = UDim2.new(0, 100, 0, 14)
			espDistLabel.Position = UDim2.new(0, headSP.X - 50, 0, headSP.Y + 6)
			espDistLabel.Visible = true
		else
			tracerLine.Visible = false
			espNameLabel.Visible = false
			espDistLabel.Visible = false
		end
	end)
end

